---
---

<section id="solution" class="py-20 bg-gradient-to-b from-gray-50 to-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-sm font-semibold text-primary-600 uppercase tracking-wide mb-2" data-i18n="sol.eyebrow">কেন আলাদা</p>
      <h2 class="font-bengali text-3xl sm:text-4xl font-bold text-gray-900 mb-3" data-i18n="sol.h2">
        কেন HMS SaaS আলাদা?
      </h2>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto" data-i18n="sol.sub">তিনটি feature যা বাংলাদেশের অন্য কোনো HMS-এ নেই</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <!-- Cloud-Native -->
      <div class="group relative bg-white rounded-2xl border border-gray-100 p-8 hover:shadow-xl hover:border-primary-200 transition-all duration-300 ease-out">
        <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-cyan-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-blue-200/50 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="sol.1.h">☁️ Cloud-Native — কোনো সার্ভার ছাড়া</h3>
        <ul class="space-y-2.5 text-sm text-slate-600">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="sol.1.li1">Cloudflare-এর global edge-এ চলে</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="sol.1.li2">কোনো সার্ভার কেনা লাগবে না, IT person লাগবে না</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="sol.1.li3">ব্রাউজার থেকে চলে — 3G-তেও কাজ করে</span>
          </li>
        </ul>
        <div class="mt-6 pt-4 border-t border-gray-100">
          <p class="text-xs text-slate-400 flex items-center gap-1">
            <svg class="w-3.5 h-3.5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
            <span data-i18n="sol.1.vs">প্রতিযোগী: নিজস্ব সার্ভার কিনতে হয়, রক্ষণাবেক্ষণ করতে হয়</span>
          </p>
        </div>
      </div>

      <!-- AI Assistant -->
      <div class="group relative bg-white rounded-2xl border border-gray-100 p-8 hover:shadow-xl hover:border-primary-200 transition-all duration-300 ease-out">
        <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-purple-200/50 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="sol.2.h">🤖 AI Medical Assistant</h3>
        <ul class="space-y-2.5 text-sm text-slate-600">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-purple-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="sol.2.li1">রোগীর পুরো চিকিৎসার ইতিহাস মনে রাখে — বার বার জিজ্ঞেস করতে হয় না</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-purple-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="sol.2.li2">বুদ্ধিমান প্রেসক্রিপশন পরামর্শ দেয়</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-purple-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="sol.2.li3">পুরনো ল্যাব রিপোর্ট PDF পড়তে ও বিশ্লেষণ করতে পারে</span>
          </li>
        </ul>
        <div class="mt-6 pt-4 border-t border-gray-100">
          <p class="text-xs text-slate-400 flex items-center gap-1">
            <svg class="w-3.5 h-3.5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
            <span data-i18n="sol.2.vs">প্রতিযোগী: AI-এর কথা বলে, কিন্তু আসলে নেই</span>
          </p>
        </div>
      </div>

      <!-- Telemedicine -->
      <div class="group relative bg-white rounded-2xl border border-gray-100 p-8 hover:shadow-xl hover:border-primary-200 transition-all duration-300 ease-out">
        <div class="w-14 h-14 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-emerald-200/50 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="sol.3.h">📹 Telemedicine Built-In</h3>
        <ul class="space-y-2.5 text-sm text-slate-600">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="sol.3.li1">HD ভিডিও consultation — একই system থেকে</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="sol.3.li2">Add-on না — built-in, কোনো extra charge নেই</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="sol.3.li3">e-Prescription QR code-এ share করুন</span>
          </li>
        </ul>
        <div class="mt-6 pt-4 border-t border-gray-100">
          <p class="text-xs text-slate-400 flex items-center gap-1">
            <svg class="w-3.5 h-3.5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
            <span data-i18n="sol.3.vs">প্রতিযোগী: কোনো telemedicine নেই</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
