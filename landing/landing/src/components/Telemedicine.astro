---
---

<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary-600 uppercase tracking-wide mb-2" data-i18n="tele.eyebrow">Advanced Features</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3" data-i18n="tele.h2">
        Telemedicine & AI — Built In
      </h2>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto" data-i18n="tele.sub">
        Not add-ons. Full-featured video consultations and AI medical assistant included.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- Telemedicine -->
      <div class="bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-lg hover:border-primary-200 transition-all duration-300 ease-out">
        <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path d="M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="tele.1.h">Telemedicine</h3>
        <p class="text-slate-500 mb-6 leading-relaxed" data-i18n="tele.1.p">
          Consult patients from anywhere. Ultra-low latency video powered by Cloudflare Realtime SFU with Jitsi fallback.
        </p>
        <!-- Mockup -->
        <div class="bg-gray-900 rounded-xl p-4 mb-6">
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-gray-800 rounded-lg aspect-video flex items-center justify-center">
              <div class="text-center">
                <div class="w-12 h-12 mx-auto bg-primary-500/20 rounded-full flex items-center justify-center mb-2 border border-primary-400/30">
                  <svg class="w-6 h-6 text-primary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <div class="text-xs text-gray-400">Dr. Kamal</div>
              </div>
            </div>
            <div class="bg-gray-800 rounded-lg aspect-video flex items-center justify-center">
              <div class="text-center">
                <div class="w-12 h-12 mx-auto bg-emerald-500/20 rounded-full flex items-center justify-center mb-2 border border-emerald-400/30">
                  <svg class="w-6 h-6 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <div class="text-xs text-gray-400">Patient</div>
              </div>
            </div>
          </div>
          <div class="flex justify-center gap-3 mt-4">
            <button class="w-10 h-10 rounded-full bg-gray-700 flex items-center justify-center text-white hover:bg-gray-600 transition-colors duration-150" aria-label="Mute">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
            </button>
            <button class="w-10 h-10 rounded-full bg-red-500 flex items-center justify-center text-white hover:bg-red-600 transition-colors duration-150" aria-label="End call">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 8l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2M5 3a2 2 0 00-2 2v1c0 8.284 6.716 15 15 15h1a2 2 0 002-2v-3.28a1 1 0 00-.684-.948l-4.493-1.498a1 1 0 00-1.21.502l-1.13 2.257a11.042 11.042 0 01-5.516-5.517l2.257-1.128a1 1 0 00.502-1.21L9.228 3.683A1 1 0 008.279 3H5z"/></svg>
            </button>
            <button class="w-10 h-10 rounded-full bg-gray-700 flex items-center justify-center text-white hover:bg-gray-600 transition-colors duration-150" aria-label="Camera">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            </button>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-2">
          <div class="flex items-center gap-2 text-sm text-slate-600">
            <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg>
            <span data-i18n="tele.1.li1">HD Video Calls</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-slate-600">
            <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg>
            <span data-i18n="tele.1.li2">Session Notes</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-slate-600">
            <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg>
            <span data-i18n="tele.1.li3">Jitsi Fallback</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-slate-600">
            <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg>
            <span data-i18n="tele.1.li4">Session History</span>
          </div>
        </div>
      </div>

      <!-- AI Assistant -->
      <div class="bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-lg hover:border-purple-200 transition-all duration-300 ease-out">
        <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="tele.2.h">AI Medical Assistant</h3>
        <p class="text-slate-500 mb-6 leading-relaxed" data-i18n="tele.2.p">
          Intelligent medical assistant that remembers patient history across sessions. Powered by OpenRouter LLMs.
        </p>
        <!-- Chat mockup -->
        <div class="bg-gray-900 rounded-xl p-4 space-y-3 mb-6">
          <div class="flex gap-2">
            <div class="w-7 h-7 rounded-full bg-purple-500/30 flex items-center justify-center text-xs text-purple-300 font-bold flex-shrink-0">AI</div>
            <div class="bg-gray-800 rounded-lg px-3 py-2 text-sm text-gray-300 max-w-[80%] leading-relaxed">
              Patient Rahim has elevated BP (150/95) for the last 3 visits. Consider reviewing medication dosage.
            </div>
          </div>
          <div class="flex gap-2 justify-end">
            <div class="bg-primary-600 rounded-lg px-3 py-2 text-sm text-white max-w-[80%]">
              Show me Rahim's lab results from last month
            </div>
            <div class="w-7 h-7 rounded-full bg-primary-500 flex items-center justify-center text-xs text-white font-bold flex-shrink-0">Dr</div>
          </div>
          <div class="flex gap-2">
            <div class="w-7 h-7 rounded-full bg-purple-500/30 flex items-center justify-center text-xs text-purple-300 font-bold flex-shrink-0">AI</div>
            <div class="bg-gray-800 rounded-lg px-3 py-2 text-sm text-gray-300 max-w-[80%] leading-relaxed">
              Lab results (Feb 15): Creatinine 1.4 mg/dL
              <span class="inline-flex items-center gap-0.5 text-yellow-400">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              </span>, HbA1c 7.2% — suggest renal function follow-up.
            </div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-2">
          <div class="flex items-center gap-2 text-sm text-slate-600">
            <svg class="w-4 h-4 text-purple-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg>
            <span data-i18n="tele.2.li1">Medical Knowledge</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-slate-600">
            <svg class="w-4 h-4 text-purple-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg>
            <span data-i18n="tele.2.li2">Long-term Memory</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-slate-600">
            <svg class="w-4 h-4 text-purple-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg>
            <span data-i18n="tele.2.li3">PDF Analysis</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-slate-600">
            <svg class="w-4 h-4 text-purple-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg>
            <span data-i18n="tele.2.li4">Per-tenant Rate Limiting</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
