---
---

<section id="about" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Founder Info -->
      <div>
        <p class="text-sm font-semibold text-primary-600 uppercase tracking-wide mb-2" data-i18n="story.eyebrow">Founder Story</p>
        <h2 class="font-bengali text-3xl sm:text-4xl font-bold text-gray-900 mb-6 leading-tight" data-i18n="story.h2">
          কে বানিয়েছে Ozzyl HMS?
        </h2>

        <div class="space-y-4 text-slate-600 leading-relaxed font-bengali">
          <p class="text-lg" data-i18n="story.p1">
            আমার নাম <strong>Rahmatullah Zisan</strong>। আমি একজন বাংলাদেশি সফটওয়্যার ডেভেলপার।
          </p>
          <p data-i18n="story.p2">
            আমি Ozzyl HMS বানিয়েছি কারণ আমি দেখেছি বাংলাদেশের হাসপাতালগুলোর জন্য সঠিক software নেই। যা আছে সেগুলো হয় খুব ব্যয়বহুল, নয়তো বাংলাদেশের জন্য তৈরি না।
          </p>
          <p data-i18n="story.p3">
            এই software সম্পূর্ণ <strong>cloud-native</strong>, Cloudflare-এর global edge-এ চলে, সম্পূর্ণ <strong>বাংলাদেশের জন্যই</strong> ডিজাইন করা — বাংলা ভাষায়, bKash/Nagad পেমেন্টে, 3G ইন্টারনেটে।
          </p>
        </div>

        <!-- Direct contact -->
        <div class="mt-8 p-5 bg-emerald-50 border border-emerald-100 rounded-xl">
          <p class="text-sm font-semibold text-emerald-800 mb-3 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span data-i18n="story.contact">সরাসরি Founder-এর সাথে কথা বলুন:</span>
          </p>
          <a
            href="https://wa.me/8801739416661"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-emerald-500 text-white font-semibold rounded-lg hover:bg-emerald-600 transition-colors duration-200 cursor-pointer text-sm"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span data-i18n="story.wa.btn">💬 WhatsApp: +880 1739-416661</span>
          </a>
        </div>
      </div>

      <!-- Right: Tech Stack & Credibility -->
      <div class="space-y-6">
        <!-- Stats -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-gray-50 border border-gray-100 rounded-xl p-5 text-center">
            <div class="text-3xl font-bold text-primary-600">20+</div>
            <div class="text-sm text-slate-500 mt-1">Modules</div>
          </div>
          <div class="bg-gray-50 border border-gray-100 rounded-xl p-5 text-center">
            <div class="text-3xl font-bold text-primary-600">373</div>
            <div class="text-sm text-slate-500 mt-1">Automated Tests</div>
          </div>
          <div class="bg-gray-50 border border-gray-100 rounded-xl p-5 text-center">
            <div class="text-3xl font-bold text-primary-600">34</div>
            <div class="text-sm text-slate-500 mt-1">Test Files</div>
          </div>
          <div class="bg-gray-50 border border-gray-100 rounded-xl p-5 text-center">
            <div class="text-3xl font-bold text-primary-600">2</div>
            <div class="text-sm text-slate-500 mt-1">Languages (EN + বাংলা)</div>
          </div>
        </div>

        <!-- Tech logos as text -->
        <div class="bg-slate-900 rounded-xl p-6">
          <p class="text-xs text-slate-400 uppercase tracking-wide mb-4 font-semibold">Technology Stack</p>
          <div class="grid grid-cols-2 gap-3">
            <div class="flex items-center gap-2 text-sm text-slate-300">
              <span class="w-2 h-2 rounded-full bg-orange-400"></span>
              Cloudflare Workers
            </div>
            <div class="flex items-center gap-2 text-sm text-slate-300">
              <span class="w-2 h-2 rounded-full bg-blue-400"></span>
              React 19
            </div>
            <div class="flex items-center gap-2 text-sm text-slate-300">
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
              D1 (SQLite)
            </div>
            <div class="flex items-center gap-2 text-sm text-slate-300">
              <span class="w-2 h-2 rounded-full bg-purple-400"></span>
              OpenAI / AI
            </div>
            <div class="flex items-center gap-2 text-sm text-slate-300">
              <span class="w-2 h-2 rounded-full bg-red-400"></span>
              Hono Framework
            </div>
            <div class="flex items-center gap-2 text-sm text-slate-300">
              <span class="w-2 h-2 rounded-full bg-yellow-400"></span>
              Cloudflare R2
            </div>
          </div>
        </div>

        <!-- Production proof -->
        <div class="bg-primary-50 border border-primary-100 rounded-xl p-5">
          <p class="text-sm text-primary-700 flex items-center gap-2 font-medium">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <span data-i18n="story.prod">Production-এ চলছে — live demo দেখতে পারবেন এখনই</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
