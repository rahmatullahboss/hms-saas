type Feature = { icon: string; title: string; items: string[] };
type TabData = Record<string, Feature[]>;

const tabData: TabData = {
  core: [
    { icon: 'patient', title: 'Patient Management', items: ['OTP-based patient portal login', 'Self-book & cancel appointments', 'Health timeline (visits, labs, bills)', 'Family member management'] },
