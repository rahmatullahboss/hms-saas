    { icon: 'ipd', title: 'IPD & Inpatient', items: ['Bed assignment & management', 'Daily charges (ward, O₂, food)', 'Nurse station vitals', 'Discharge summary PDF'] },
    { icon: 'doctor', title: 'Doctor Module', items: ['Smart patient queue', 'Digital prescription writing', 'Consultation notes', 'Commission tracking & reports'] },
