---
---

<section id="founding" class="py-20 bg-gradient-to-b from-white to-emerald-50/30 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Narrative -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-50 border border-emerald-100 text-emerald-700 rounded-full text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
          <span data-i18n="found.badge">সীমিত সুযোগ — শুধুমাত্র প্রথম ১০টি হাসপাতালের জন্য</span>
        </div>

        <h2 class="font-bengali text-3xl sm:text-4xl font-bold text-gray-900 mb-6 leading-tight">
          <span data-i18n="found.h2.1">আমাদের প্রথম ১০টি</span><br>
          <span class="text-emerald-600" data-i18n="found.h2.2">Founding Hospital হন</span>
        </h2>

        <div class="space-y-4 text-slate-600 leading-relaxed mb-8">
          <p class="font-bengali text-lg" data-i18n="found.p1">
            আমরা আপনাকে সাজানো প্রশংসাপত্র দেখাবো না। আমরা নতুন।
          </p>
          <p class="font-bengali" data-i18n="found.p2">
            কিন্তু আমরা আপনাকে একটি সম্পূর্ণ চালু সফটওয়্যার দেখাতে পারি — এবং একটি সুযোগ যা পরে আর পাবেন না:
          </p>
        </div>

        <div class="space-y-3 mb-8">
          <div class="flex items-center gap-3 text-slate-700">
            <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="font-bengali font-medium" data-i18n="found.b1">ফ্রি সেটআপ — আমরা আপনার হাসপাতালে সব কিছু সেট করে দেবো</span>
          </div>
          <div class="flex items-center gap-3 text-slate-700">
            <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="font-bengali font-medium" data-i18n="found.b2">ফ্রি অনবোর্ডিং ট্রেনিং — আপনার staff-দের শেখাবো</span>
          </div>
          <div class="flex items-center gap-3 text-slate-700">
            <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="font-bengali font-medium" data-i18n="found.b3">Founder-এর সরাসরি WhatsApp — যেকোনো সমস্যায় সরাসরি কথা বলুন</span>
          </div>
          <div class="flex items-center gap-3 text-slate-700">
            <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="font-bengali font-medium" data-i18n="found.b4">আপনার মতামত সরাসরি সফটওয়্যারে যোগ হবে</span>
          </div>
        </div>

        <p class="text-primary-600 font-semibold font-bengali text-lg" data-i18n="found.cta">
          আমরা শুধু ক্রেতা খুঁজছি না — আমরা অংশীদার খুঁজছি। 🤝
        </p>
      </div>

      <!-- Right: Application Form -->
      <div class="bg-white rounded-2xl border border-gray-200 p-8 shadow-xl shadow-gray-100/80">
        <h3 class="text-xl font-bold text-gray-900 mb-2 font-bengali" data-i18n="found.form.h">Founding Hospital আবেদন</h3>
        <p class="text-sm text-slate-500 mb-6" data-i18n="found.form.sub">ফর্ম পূরণ করুন — আমরা ২৪ ঘণ্টার মধ্যে WhatsApp-এ যোগাযোগ করবো</p>

        <form id="founding-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1 font-bengali" data-i18n="found.form.hospital">হাসপাতালের নাম</label>
            <input id="hospital_name" name="hospital_name" type="text" required data-i18n-ph="found.form.hospital.ph" placeholder="যেমন: গ্রিন লাইফ হসপিটাল" class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all duration-200" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1 font-bengali" data-i18n="found.form.beds">বেড সংখ্যা</label>
            <select id="bed_count" name="bed_count" class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all duration-200 bg-white">
              <option value="10-25">১০ - ২৫ বেড</option>
              <option value="25-50">২৫ - ৫০ বেড</option>
              <option value="50-100">৫০ - ১০০ বেড</option>
              <option value="100+">১০০+ বেড</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1 font-bengali" data-i18n="found.form.wa">WhatsApp নম্বর</label>
            <input id="whatsapp_number" name="whatsapp_number" type="tel" required placeholder="01XXXXXXXXX" class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all duration-200" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1 font-bengali" data-i18n="found.form.name">যোগাযোগকারীর নাম (ঐচ্ছিক)</label>
            <input id="contact_name" name="contact_name" type="text" data-i18n-ph="found.form.name.ph" placeholder="আপনার নাম" class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all duration-200" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1 font-bengali" data-i18n="found.form.email">ইমেইল (ঐচ্ছিক)</label>
            <input id="email" name="email" type="email" placeholder="your@email.com" class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all duration-200" />
          </div>

          <!-- Success Message -->
          <div id="form-success" class="hidden p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-center">
            <p class="text-emerald-700 font-bengali font-medium" data-i18n="found.form.success1">✅ আবেদন সফলভাবে জমা হয়েছে!</p>
            <p class="text-emerald-600 text-sm font-bengali mt-1" data-i18n="found.form.success2">আমরা শীঘ্রই WhatsApp-এ যোগাযোগ করবো।</p>
          </div>

          <!-- Error Message -->
          <div id="form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl text-center">
            <p id="form-error-text" class="text-red-700 font-bengali font-medium text-sm"></p>
          </div>

          <button
            id="submit-btn"
            type="submit"
            class="flex items-center justify-center gap-2 w-full px-6 py-3.5 bg-emerald-500 text-white font-bold rounded-xl hover:bg-emerald-600 transition-all duration-200 ease-out text-lg shadow-lg shadow-emerald-200/50 cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span id="submit-text" data-i18n="found.form.submit">আবেদন জমা দিন</span>
          </button>
        </form>

        <script>
          const currentLang = (): string => localStorage.getItem('hms-lang') ?? 'bn';
          const t = (en: string, bn: string) => currentLang() === 'en' ? en : bn;

          document.getElementById('founding-form')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
            const text = document.getElementById('submit-text');
            const successEl = document.getElementById('form-success');
            const errorEl = document.getElementById('form-error');
            const errorText = document.getElementById('form-error-text');

            if (!btn || !text || !successEl || !errorEl || !errorText) return;

            successEl.classList.add('hidden');
            errorEl.classList.add('hidden');
            btn.disabled = true;
            text.textContent = t('Submitting...', 'জমা হচ্ছে...');

            try {
              const API_URL = (import.meta as any).env?.PUBLIC_HMS_API_URL ?? 'http://localhost:8787';
              const res = await fetch(`${API_URL}/api/onboarding/apply`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  hospital_name: (document.getElementById('hospital_name') as HTMLInputElement)?.value,
                  bed_count: (document.getElementById('bed_count') as HTMLSelectElement)?.value,
                  whatsapp_number: (document.getElementById('whatsapp_number') as HTMLInputElement)?.value,
                  contact_name: (document.getElementById('contact_name') as HTMLInputElement)?.value || undefined,
                  email: (document.getElementById('email') as HTMLInputElement)?.value || undefined,
                }),
              });

              const data = await res.json() as { error?: string };
              if (res.ok) {
                successEl.classList.remove('hidden');
                (e.target as HTMLFormElement).reset();
              } else {
                errorText.textContent = data.error ?? t('Failed to submit application.', 'আবেদন জমা দিতে সমস্যা হয়েছে।');
                errorEl.classList.remove('hidden');
              }
            } catch {
              errorText.textContent = t('Network error — please try again.', 'নেটওয়ার্ক সমস্যা — পরে আবার চেষ্টা করুন।');
              errorEl.classList.remove('hidden');
            } finally {
              btn.disabled = false;
              text.textContent = t('Submit Application', 'আবেদন জমা দিন');
            }
          });
        </script>

        <p class="text-xs text-slate-400 text-center mt-4 flex items-center justify-center gap-1">
          <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          <span data-i18n="found.secure">আপনার তথ্য সম্পূর্ণ নিরাপদ</span>
        </p>
      </div>
    </div>
  </div>
</section>
