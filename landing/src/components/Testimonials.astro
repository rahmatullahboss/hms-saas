---
const testimonials = [
  {
    quote: 'Ozzyl HMS সব কিছু এক জায়গায় এনে দিয়েছে — billing থেকে lab পর্যন্ত।',
    name: 'Dr. Kamal Ahmed',
    role: 'Director',
    org: 'Apollo Clinic, Dhaka',
    color: 'indigo',
  },
  {
    quote: 'Billing errors এখন শূন্যে নেমে এসেছে। Staff-রাও খুশি।',
    name: 'Nasrin Akter',
    role: 'Hospital Admin',
    org: 'City Hospital, Chittagong',
    color: 'emerald',
  },
  {
    quote: 'Phone থেকেই live revenue দেখতে পাই — যেকোনো জায়গা থেকে।',
    name: 'Rahman Chowdhury',
    role: 'Managing Director',
    org: 'Green Life Hospital',
    color: 'orange',
  },
];
---

<section id="testimonials" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary-600 uppercase tracking-wide mb-2">Testimonials</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">
        Trusted by Bangladesh Hospitals
      </h2>
      <p class="text-slate-500 text-lg">Join hospitals that made the switch</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {testimonials.map(t => (
        <div class="bg-gray-50 rounded-2xl border border-gray-100 p-7 hover:shadow-lg hover:border-primary-100 transition-all duration-300 ease-out flex flex-col">
          <!-- Stars -->
          <div class="flex gap-1 mb-5">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
              </svg>
            ))}
          </div>

          <!-- Large quote mark -->
          <svg class="w-8 h-8 text-primary-100 mb-3 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>

          <!-- Quote -->
          <p class="text-slate-700 font-bengali mb-6 text-base leading-relaxed flex-1">{t.quote}</p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-gray-200">
            <div class={`w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0 ${
              t.color === 'indigo' ? 'bg-primary-100 text-primary-600' :
              t.color === 'emerald' ? 'bg-emerald-100 text-emerald-600' :
              'bg-orange-100 text-orange-600'
            }`}>
              {t.name.split(' ').map((n: string) => n[0]).join('')}
            </div>
            <div>
              <div class="font-semibold text-gray-900 text-sm">{t.name}</div>
              <div class="text-xs text-slate-500">{t.role}, {t.org}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
