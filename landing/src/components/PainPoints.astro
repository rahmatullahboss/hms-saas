---
---

<section class="py-20 bg-white relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary-200 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-sm font-semibold text-red-500 uppercase tracking-wide mb-2 flex items-center justify-center gap-1.5">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <span data-i18n="pain.eyebrow">সমস্যা চিনুন</span>
      </p>
      <h2 class="font-bengali text-3xl sm:text-4xl font-bold text-gray-900 mb-3" data-i18n="pain.h2">
        আপনার হাসপাতাল কি এখনও এভাবে চলছে?
      </h2>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto" data-i18n="pain.sub">বাংলাদেশের ৭০% হাসপাতাল এখনও কাগজ আর খাতায় চলছে — এর ফলে প্রতিদিন রোগীর তথ্য হারাচ্ছে, বিলিং ভুল হচ্ছে, আর লক্ষ টাকা আয় হারিয়ে যাচ্ছে।</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto mb-12">
      <!-- Pain 1 -->
      <div class="group relative bg-red-50/50 border border-red-100 rounded-2xl p-7 hover:shadow-lg hover:border-red-200 transition-all duration-300 ease-out">
        <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h3 class="font-bengali text-lg font-bold text-gray-900 mb-2" data-i18n="pain.1.h">📋 কাগজে রোগীর তথ্য</h3>
        <p class="text-sm text-slate-600 leading-relaxed" data-i18n="pain.1.p">ফাইল হারিয়ে যায়, হাতের লেখা বোঝা যায় না, পুরনো রিপোর্ট খুঁজে পাওয়া অসম্ভব — রোগীর সেবা ক্ষতিগ্রস্ত হচ্ছে।</p>
      </div>

      <!-- Pain 2 -->
      <div class="group relative bg-orange-50/50 border border-orange-100 rounded-2xl p-7 hover:shadow-lg hover:border-orange-200 transition-all duration-300 ease-out">
        <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        </div>
        <h3 class="font-bengali text-lg font-bold text-gray-900 mb-2" data-i18n="pain.2.h">💬 WhatsApp-এ সমন্বয়</h3>
        <p class="text-sm text-slate-600 leading-relaxed" data-i18n="pain.2.p">অ্যাপয়েন্টমেন্ট WhatsApp গ্রুপে, বিলিং ফোনে — কোনো সিস্টেম নেই, কোনো রেকর্ড নেই, কোনো জবাবদিহিতা নেই।</p>
      </div>

      <!-- Pain 3 -->
      <div class="group relative bg-purple-50/50 border border-purple-100 rounded-2xl p-7 hover:shadow-lg hover:border-purple-200 transition-all duration-300 ease-out">
        <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="font-bengali text-lg font-bold text-gray-900 mb-2" data-i18n="pain.3.h">💰 বিলিং-এ ভুল ও Revenue Leak</h3>
        <p class="text-sm text-slate-600 leading-relaxed" data-i18n="pain.3.p">হাতে হিসেব লেখায় প্রতিদিন ভুল হচ্ছে, একই বিল দুইবার — বকেয়া ট্র্যাক করা যাচ্ছে না, মাসে লক্ষ টাকা হারিয়ে যাচ্ছে।</p>
      </div>
    </div>

    <div class="text-center">
      <a href="#solution" class="inline-flex items-center gap-2 text-primary-600 font-semibold hover:text-primary-700 transition-colors duration-200 text-lg group">
        <span data-i18n="pain.link">Ozzyl HMS এই তিনটি সমস্যার সমাধান করে — এক সিস্টেমে</span>
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
