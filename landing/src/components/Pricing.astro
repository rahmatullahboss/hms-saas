<!-- Billing toggle script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('billing-toggle');
    const annualNote = document.getElementById('annual-note');
    if (!toggle) return;

    let isAnnual = false;
    toggle.addEventListener('click', () => {
      isAnnual = !isAnnual;
      toggle.setAttribute('aria-pressed', String(isAnnual));
      // Move the toggle knob
      const knob = toggle.querySelector('span');
      if (knob) {
        knob.style.transform = isAnnual ? 'translateX(1.25rem)' : 'translateX(0)';
      }
      toggle.style.backgroundColor = isAnnual ? 'var(--color-primary-600, #4f46e5)' : '#d1d5db';

      // Update prices
      document.querySelectorAll<HTMLElement>('.price-amount').forEach(el => {
        const monthly = el.dataset.monthly || '';
        const annual = el.dataset.annual || '';
        el.textContent = isAnnual ? annual : monthly;
      });

      // Show/hide annual note
      if (annualNote) {
        annualNote.classList.toggle('hidden', !isAnnual);
      }
    });
  });
</script>
