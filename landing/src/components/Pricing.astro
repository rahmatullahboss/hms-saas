---

<section id="pricing" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary-600 uppercase tracking-wide mb-2" data-i18n="price.eyebrow">Pricing</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3" data-i18n="price.h2">Simple, Transparent Pricing</h2>
      <p class="text-lg text-slate-500" data-i18n="price.sub">30-day free trial. No credit card required.</p>
      <!-- Annual toggle -->
      <div class="mt-6 inline-flex items-center gap-3 bg-white border border-gray-200 rounded-full px-4 py-2 shadow-sm">
        <span class="text-sm font-medium text-gray-700" data-i18n="price.monthly">Monthly</span>
        <button id="billing-toggle" type="button" class="relative w-11 h-6 bg-gray-300 rounded-full transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2" aria-pressed="false" aria-label="Toggle annual billing">
          <span class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full shadow-sm transition-transform duration-200"></span>
        </button>
        <span class="text-sm font-medium text-gray-700" data-i18n="price.annually">Annually</span>
        <span class="text-xs font-bold text-green-600 bg-green-50 px-2 py-0.5 rounded-full" data-i18n="price.save">2 months free</span>
      </div>
    </div>

    <!-- Pricing Cards -->
    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto mb-12 items-center">

      <!-- Starter -->
      <div class="relative rounded-2xl p-8 flex flex-col bg-white border border-gray-200 text-gray-900 hover:border-primary-300 hover:shadow-lg transition-all duration-200">
        <div class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-2" data-i18n="price.s.badge">Small Clinics</div>
        <div class="mb-6">
          <h3 class="text-xl font-bold mb-2 text-gray-900" data-i18n="price.s.name">Starter</h3>
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold font-bengali price-amount" data-monthly="৳ 3,000" data-annual="৳ 2,500">৳ 3,000</span>
            <span class="text-sm text-slate-400" data-i18n="price.period">/month</span>
          </div>
          <div class="text-sm mt-1.5 flex items-center gap-1 text-slate-400">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            <span data-i18n="price.s.beds">&lt; 25 beds</span>
          </div>
        </div>
        <ul class="space-y-3 mb-6 flex-1">
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.s.f1">OPD + Reception + Billing</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.s.f2">Laboratory + Pharmacy</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.s.f3">Patient Management</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.s.f4">5 Staff accounts</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.s.f5">Bangla + English</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.s.f6">Email support</span></li>
        </ul>
        <!-- Add-on badges -->
        <div class="mb-4 space-y-2">
          <div class="flex items-center gap-2 text-xs">
            <span class="px-2 py-1 bg-blue-50 text-blue-600 rounded-full font-medium" data-i18n="price.addon.ai">+ AI Assistant ৳1,500/mo</span>
          </div>
          <div class="flex items-center gap-2 text-xs">
            <span class="px-2 py-1 bg-purple-50 text-purple-600 rounded-full font-medium" data-i18n="price.addon.tele">+ Telemedicine ৳2,000/mo</span>
          </div>
        </div>
        <a href="https://hms-saas-production.rahmatullahzisan.workers.dev/signup" class="block text-center py-3 px-6 rounded-xl font-semibold text-sm transition-all duration-200 ease-out cursor-pointer border-2 border-primary-600 text-primary-600 hover:bg-primary-600 hover:text-white" data-i18n="price.s.cta">Start Free Trial</a>
      </div>

      <!-- Professional -->
      <div class="relative rounded-2xl p-8 flex flex-col bg-gradient-to-br from-primary-600 to-primary-700 text-white shadow-2xl shadow-primary-300/40 scale-[1.04] z-10">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1.5 bg-orange-500 text-white text-xs font-bold rounded-full shadow-md tracking-wide uppercase" data-i18n="price.p.badge">MOST POPULAR</div>
        <div class="mb-6">
          <h3 class="text-xl font-bold mb-2 text-white" data-i18n="price.p.name">Professional</h3>
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold font-bengali price-amount" data-monthly="৳ 7,000" data-annual="৳ 5,833">৳ 7,000</span>
            <span class="text-sm text-primary-100" data-i18n="price.period">/month</span>
          </div>
          <div class="text-sm mt-1.5 flex items-center gap-1 text-primary-100">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            <span data-i18n="price.p.beds">&lt; 100 beds</span>
          </div>
        </div>
        <ul class="space-y-3 mb-8 flex-1">
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-primary-50" data-i18n="price.p.f1">Everything in Starter</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-primary-50" data-i18n="price.p.f2">Full IPD + Nurse Station</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-primary-50" data-i18n="price.p.f3">Full Accounting + Reports</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-primary-50" data-i18n="price.p.f4">AI + Telemedicine included</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-primary-50" data-i18n="price.p.f5">20 Staff accounts</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-primary-50" data-i18n="price.p.f6">Doctor Scheduling</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-primary-50" data-i18n="price.p.f7">Multi-branch support</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-primary-50" data-i18n="price.p.f8">Priority support</span></li>
        </ul>
        <a href="https://hms-saas-production.rahmatullahzisan.workers.dev/signup" class="block text-center py-3 px-6 rounded-xl font-semibold text-sm transition-all duration-200 ease-out cursor-pointer bg-white text-primary-600 hover:bg-orange-50 hover:text-orange-600 shadow-sm" data-i18n="price.p.cta">Start Free Trial</a>
      </div>

      <!-- Enterprise -->
      <div class="relative rounded-2xl p-8 flex flex-col bg-white border border-gray-200 text-gray-900 hover:border-primary-300 hover:shadow-lg transition-all duration-200">
        <div class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-2" data-i18n="price.e.badge">Large Hospitals</div>
        <div class="mb-6">
          <h3 class="text-xl font-bold mb-2 text-gray-900" data-i18n="price.e.name">Enterprise</h3>
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold font-bengali price-amount" data-monthly="৳ 15,000" data-annual="৳ 12,500">৳ 15,000</span>
            <span class="text-sm text-slate-400" data-i18n="price.period">/month</span>
          </div>
          <div class="text-sm mt-1.5 flex items-center gap-1 text-slate-400">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            <span data-i18n="price.e.beds">100+ beds / Multi-branch</span>
          </div>
        </div>
        <ul class="space-y-3 mb-8 flex-1">
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.e.f1">Everything in Professional</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.e.f2">AI Medical Assistant</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.e.f3">Unlimited staff</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.e.f4">Custom branding</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.e.f5">SLA guarantee</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.e.f6">Dedicated onboarding</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.e.f7">FHIR R4 Interoperability</span></li>
          <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg><span class="text-slate-600" data-i18n="price.e.f8">API Access</span></li>
        </ul>
        <a href="https://hms-saas-production.rahmatullahzisan.workers.dev/signup" class="block text-center py-3 px-6 rounded-xl font-semibold text-sm transition-all duration-200 ease-out cursor-pointer border-2 border-primary-600 text-primary-600 hover:bg-primary-600 hover:text-white" data-i18n="price.e.cta">Start Free Trial</a>
      </div>
    </div>

    <!-- Annual savings note -->
    <div class="text-center mb-8 hidden" id="annual-note">
      <p class="text-sm text-green-600 font-medium" data-i18n="price.annual.note">💡 Annual billing = 10 months price for 12 months. Save 2 months!</p>
    </div>

    <!-- No setup fee banner -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center gap-2 px-5 py-2.5 bg-green-50 border border-green-200 rounded-full">
        <svg class="w-4 h-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7" /></svg>
        <span class="text-sm font-medium text-green-700" data-i18n="price.nosetup">30-day free trial · No setup fee · Cancel anytime</span>
      </div>
    </div>

    <!-- Payment methods -->
    <div class="text-center mb-16">
      <p class="text-sm text-slate-500 font-bengali mb-4" data-i18n="price.payment">Pay in Bangladesh:</p>
      <div class="flex items-center justify-center gap-6 flex-wrap">
        <div class="flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-lg shadow-sm text-sm font-medium text-slate-600">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          <span data-i18n="price.pay.bkash">bKash</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-lg shadow-sm text-sm font-medium text-slate-600">
          <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg>
          <span data-i18n="price.pay.nagad">Nagad</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-lg shadow-sm text-sm font-medium text-slate-600">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 6l3 1m0 0l-3 9a5 5 0 006.9 5.06L15 8m-9 0l-3 9m12-9l3 9a5 5 0 01-6.9 5.06L9 8m6 0l-3-1m0 0l3-9"/></svg>
          <span data-i18n="price.pay.bank">Bank Transfer</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-lg shadow-sm text-sm font-medium text-slate-600">
          <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          <span data-i18n="price.pay.card">Credit / Debit Card</span>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="max-w-3xl mx-auto">
      <h3 class="text-2xl font-bold text-gray-900 text-center mb-8" data-i18n="price.faq">Frequently Asked Questions</h3>
      <div class="space-y-3">
        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-primary-200 transition-colors duration-200">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-gray-900 group-hover:text-primary-600 transition-colors duration-200 list-none">
            <span data-i18n="price.faq.q1">Is there a free trial?</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200 ease-out" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-5 pb-5 text-sm text-slate-600 leading-relaxed border-t border-gray-100 pt-3" data-i18n="price.faq.a1">Yes! 30 days free. No credit card required. Cancel anytime.</div>
        </details>
        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-primary-200 transition-colors duration-200">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-gray-900 group-hover:text-primary-600 transition-colors duration-200 list-none">
            <span data-i18n="price.faq.q2">Is patient data secure?</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200 ease-out" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-5 pb-5 text-sm text-slate-600 leading-relaxed border-t border-gray-100 pt-3" data-i18n="price.faq.a2">Absolutely. Data is encrypted on Cloudflare edge servers with daily backups. We follow HIPAA-ready security practices.</div>
        </details>
        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-primary-200 transition-colors duration-200">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-gray-900 group-hover:text-primary-600 transition-colors duration-200 list-none">
            <span data-i18n="price.faq.q3">Does it support bKash payment?</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200 ease-out" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-5 pb-5 text-sm text-slate-600 leading-relaxed border-t border-gray-100 pt-3" data-i18n="price.faq.a3">Yes. We accept bKash, Nagad, bank transfer, and credit/debit cards.</div>
        </details>
        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-primary-200 transition-colors duration-200">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-gray-900 group-hover:text-primary-600 transition-colors duration-200 list-none">
            <span data-i18n="price.faq.q4">Can I switch plans later?</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200 ease-out" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-5 pb-5 text-sm text-slate-600 leading-relaxed border-t border-gray-100 pt-3" data-i18n="price.faq.a4">Yes, you can upgrade or downgrade your plan at any time. Changes take effect immediately.</div>
        </details>
        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-primary-200 transition-colors duration-200">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-gray-900 group-hover:text-primary-600 transition-colors duration-200 list-none">
            <span data-i18n="price.faq.q5">Does it work on mobile phones with slow internet?</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200 ease-out" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-5 pb-5 text-sm text-slate-600 leading-relaxed border-t border-gray-100 pt-3" data-i18n="price.faq.a5">Yes. The system is optimised for 3G/4G connections and works on any smartphone browser. A native Android APK is also available.</div>
        </details>
        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-primary-200 transition-colors duration-200">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-gray-900 group-hover:text-primary-600 transition-colors duration-200 list-none">
            <span data-i18n="price.faq.q6">Is there any setup fee?</span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200 ease-out" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
          </summary>
