  function applyLang(lang) {
    // Update html lang attr
    document.documentElement.lang = lang === 'bn' ? 'bn' : 'en';

    // Update all data-i18n text nodes
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n;
      const val = dict[lang][key];
      if (val !== undefined) {
        if (val.includes('<')) {
          el.innerHTML = val;
        } else {
          el.textContent = val;
        }
      }
    });

    // Update placeholders
    document.querySelectorAll('[data-i18n-ph]').forEach(el => {
      const key = el.dataset.i18nPh;
      const val = dict[lang][key];
      if (val !== undefined) el.placeholder = val;
    });

    // Update toggle button state
    const btnEn = document.getElementById('lang-btn-en');
    const btnBn = document.getElementById('lang-btn-bn');
    if (btnEn && btnBn) {
      btnEn.classList.toggle('font-bold', lang === 'en');
      btnEn.classList.toggle('text-primary-600', lang === 'en');
      btnEn.classList.toggle('text-gray-400', lang !== 'en');
      btnBn.classList.toggle('font-bold', lang === 'bn');
      btnBn.classList.toggle('text-primary-600', lang === 'bn');
      btnBn.classList.toggle('text-gray-400', lang !== 'bn');
    }

    localStorage.setItem('hms-lang', lang);
    document.dispatchEvent(new CustomEvent('langchange', { detail: { lang } }));
  }

  // ── Boot ────────────────────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    const saved = localStorage.getItem('hms-lang') ?? 'bn';
    applyLang(saved);

    document.getElementById('lang-btn-en')?.addEventListener('click', () => applyLang('en'));
    document.getElementById('lang-btn-bn')?.addEventListener('click', () => applyLang('bn'));
  });

  // Expose for programmatic use
  window.setLang = applyLang;
</script>
