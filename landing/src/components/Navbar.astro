---
---

<!-- Announcement Bar -->
<div class="bg-emerald-50 border-b border-emerald-100">
  <div class="max-w-7xl mx-auto px-4 py-2 text-center text-sm text-emerald-700 flex items-center justify-center gap-2">
    <svg class="w-4 h-4 flex-shrink-0 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
    <span>
      <span data-i18n="nav.announce">🎉 Founding Hospital Program: প্রথম ১০টি হাসপাতালের জন্য ফ্রি সেটআপ —</span>
      <a href="#founding" class="font-semibold underline hover:text-emerald-900 transition-colors duration-200" data-i18n="nav.announce.link">আবেদন করুন →</a>
    </span>
  </div>
</div>

<!-- Main Navbar -->
<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5">
        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        </div>
        <span class="text-lg font-bold text-gray-900">HMS SaaS</span>
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#features" class="text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors duration-200" data-i18n="nav.features">ফিচার</a>
        <a href="#pricing" class="text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors duration-200" data-i18n="nav.pricing">মূল্য</a>
        <a href="#founding" class="text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors duration-200" data-i18n="nav.founding">Founding Program</a>
        <a href="#about" class="text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors duration-200" data-i18n="nav.about">About</a>
      </div>

      <!-- CTA Buttons + Language Toggle -->
      <div class="flex items-center gap-3">

        <!-- EN / BN Toggle -->
        <div class="hidden sm:flex items-center gap-0.5 bg-gray-100 rounded-lg p-0.5">
          <button
            id="lang-btn-en"
            class="px-2.5 py-1 rounded-md text-xs font-bold text-gray-400 hover:text-gray-700 transition-all duration-150 cursor-pointer"
            aria-label="Switch to English"
          >EN</button>
          <button
            id="lang-btn-bn"
            class="px-2.5 py-1 rounded-md text-xs font-bold text-primary-600 hover:text-primary-700 transition-all duration-150 cursor-pointer"
            aria-label="Switch to Bengali"
          >বাং</button>
        </div>

        <a
          href="https://hms-saas-production.rahmatullahzisan.workers.dev"
          target="_blank"
          rel="noopener"
          class="hidden sm:inline-flex text-sm font-medium text-gray-700 hover:text-primary-600 transition-colors duration-200 cursor-pointer"
          data-i18n="nav.login"
        >লগইন</a>

        <a
          href="#founding"
          class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500 text-white text-sm font-semibold rounded-lg shadow-sm hover:bg-emerald-600 transition-colors duration-200 cursor-pointer"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          <span data-i18n="nav.cta">⚡ ফ্রি সেটআপ</span>
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 hover:text-primary-600 transition-colors duration-200 cursor-pointer"
          aria-label="Open menu"
        >
          <svg id="menu-icon-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100">
    <div class="px-4 py-3 space-y-1">
      <a href="#features" class="flex items-center gap-2 text-sm font-medium text-gray-600 py-2.5 px-3 rounded-lg hover:bg-gray-50 hover:text-primary-600 transition-colors duration-200" data-i18n="nav.features">ফিচার</a>
      <a href="#pricing" class="flex items-center gap-2 text-sm font-medium text-gray-600 py-2.5 px-3 rounded-lg hover:bg-gray-50 hover:text-primary-600 transition-colors duration-200" data-i18n="nav.pricing">মূল্য</a>
      <a href="#founding" class="flex items-center gap-2 text-sm font-medium text-gray-600 py-2.5 px-3 rounded-lg hover:bg-gray-50 hover:text-primary-600 transition-colors duration-200" data-i18n="nav.founding">Founding Program</a>
      <a href="#about" class="flex items-center gap-2 text-sm font-medium text-gray-600 py-2.5 px-3 rounded-lg hover:bg-gray-50 hover:text-primary-600 transition-colors duration-200" data-i18n="nav.about">About</a>

      <!-- Mobile language toggle -->
      <div class="flex items-center gap-2 py-2.5 px-3">
        <span class="text-xs text-gray-500 font-medium">Language:</span>
        <button id="lang-btn-en-mobile" onclick="document.getElementById('lang-btn-en').click()" class="px-2.5 py-1 rounded-md text-xs font-bold bg-gray-100 text-gray-600 hover:bg-primary-100 hover:text-primary-700 transition-colors cursor-pointer">EN</button>
        <button id="lang-btn-bn-mobile" onclick="document.getElementById('lang-btn-bn').click()" class="px-2.5 py-1 rounded-md text-xs font-bold bg-gray-100 text-gray-600 hover:bg-primary-100 hover:text-primary-700 transition-colors cursor-pointer">বাং</button>
      </div>

      <div class="pt-2 border-t border-gray-100">
        <a href="#founding" class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-emerald-500 text-white text-sm font-semibold rounded-lg hover:bg-emerald-600 transition-colors duration-200" data-i18n="nav.cta">⚡ ফ্রি সেটআপ</a>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
