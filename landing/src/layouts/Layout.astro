---
import LanguageToggle from '../components/LanguageToggle.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'HMS SaaS — Hospital Management System for Bangladesh',
  description = 'Cloud-native Hospital Management System built for Bangladesh. OPD, Billing, Lab, Pharmacy, Telemedicine, AI — all in one. No server required.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OG / WhatsApp / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:locale" content="en_US" />

    <!-- SEO -->
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://hmssaas.com" />

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "HMS SaaS",
        "applicationCategory": "HealthApplication",
        "operatingSystem": "Web",
        "description": "Cloud-native Hospital Management System for Bangladesh"
      }
    </script>

    <!-- Fonts: self-hosted for CDN caching + zero external requests -->
    <link rel="preload" href="/fonts/figtree-var.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/noto-sans-bengali-var.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Analytics 4: deferred until first user interaction -->
    <!-- TODO: Replace G-XXXXXXXXXX with your real GA4 Measurement ID -->
    <script is:inline>
      (function(){
        var GA_ID = 'G-XXXXXXXXXX';
        var loaded = false;
        function loadGA() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
          s.async = true;
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', GA_ID, { send_page_view: true });
        }
        // Load after first scroll, click, or touch — not during initial paint
        ['scroll','mousedown','touchstart','keydown'].forEach(function(e){
          window.addEventListener(e, loadGA, {once: true, passive: true});
        });
        // Fallback: load after 5s even with no interaction
        setTimeout(loadGA, 5000);
      })();
    </script>
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <slot />
    <LanguageToggle />
  </body>
</html>
