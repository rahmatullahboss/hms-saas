{
  "name": "hms-saas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Multi-tenant Hospital Management System SaaS — Single Worker",
  "scripts": {
    "dev:api": "wrangler dev",
    "dev:web": "pnpm --filter web vite",
    "dev": "concurrently \"wrangler dev\" \"pnpm --filter web vite\"",
    "build": "pnpm --filter web build",
    "build:web": "pnpm --filter web build",
    "deploy": "pnpm --filter web build && wrangler deploy",
    "deploy:staging": "pnpm --filter web build && wrangler deploy --env staging",
    "deploy:production": "pnpm --filter web build && wrangler deploy --env production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:all": "vitest run && vitest run --config vitest.config.integration.ts",
    "test:coverage": "vitest run --coverage",
    "test:coverage:all": "vitest run --coverage && vitest run --config vitest.config.integration.ts --coverage",
    "test:load": "k6 run test/load/api-load.js",
    "test:load:billing": "k6 run test/load/billing-stress.js",
    "test:real:setup": "bash test/integration/real-db/setup.sh",
    "test:real": "vitest run --config vitest.config.real.ts",
    "test:real:watch": "vitest --config vitest.config.real.ts",
    "test:smoke:deploy": "npx tsx test/smoke/deploy-smoke.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:api": "playwright test --project=api",
    "test:e2e:browser": "playwright test --project=e2e",
    "test:e2e:prod": "BASE_URL=https://hms-saas-production.rahmatullahzisan.workers.dev playwright test --project=smoke --project=api",
    "test:e2e:report": "playwright show-report test/e2e/report",
    "types": "wrangler types"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "bcryptjs": "^2.4.3",
    "hono": "^4.12.8",
    "toucan-js": "^4.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.0",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^3.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  }
}
